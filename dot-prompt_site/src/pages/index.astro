---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import CodeBlock from '../components/CodeBlock.astro';

const exampleCode = `init do
  @version: 1.0
  @major: 1

  def:
    mode: explanation
    description: Teacher mode.

  params:
    @pattern_step: int[1..5] = 1
    @variation: enum[analogy, recognition]
    @user_input: str

end init

case @variation do
analogy: Use an analogy to explain.
recognition: Ask a guiding question.
end @variation

@user_input

response do
  {
    "response_type": "teaching",
    "content": "..."
  }
end response`;

const compiledOutput = `Ask a guiding question.

[user message]

Respond with this JSON:
{
  "response_type": "teaching",
  "content": "..."
}`;
---

<MarketingLayout title=".prompt - A Compiled Language for LLM Prompts">
  <!-- Hero Section -->
  <section class="relative overflow-hidden py-20 sm:py-32">
    <div class="absolute inset-0 -z-10 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-primary-100 via-transparent to-transparent dark:from-primary-900/20"></div>
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h1 class="text-4xl font-bold tracking-tight sm:text-6xl">
          A compiled language for <span class="text-gradient">LLM prompts</span>
        </h1>
        <p class="mt-6 text-lg leading-8 text-[var(--color-text-muted)]">
          Define structure, branching, and contracts in <code class="text-primary-600 dark:text-primary-400">.prompt</code> files. Ship clean prompts that compile away the complexity before they reach your LLM.
        </p>
        <div class="mt-10 flex items-center justify-center gap-x-6">
          <a href="/docs/getting-started" class="btn btn-primary">
            Get Started
          </a>
          <a href="/why" class="btn btn-secondary">
            Why .prompt?
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Code Example Section -->
  <section class="py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <div class="text-center mb-8">
          <h2 class="text-2xl font-bold">Write once, compile clean</h2>
          <p class="mt-2 text-[var(--color-text-muted)]">
            Branching resolves at compile time. The LLM receives only what it needs.
          </p>
        </div>
        <CodeBlock code={exampleCode} title="example.prompt" />
        <div class="mt-8 text-center">
          <p class="text-sm text-[var(--color-text-muted)]">
            What the LLM receives for <code class="text-primary-600">variation: recognition</code>:
          </p>
        </div>
        <CodeBlock code={compiledOutput} title="LLM receives" language="markdown" />
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-20 bg-[var(--color-surface)]">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center mb-16">
        <h2 class="text-3xl font-bold">Everything you need for prompt engineering</h2>
        <p class="mt-4 text-[var(--color-text-muted)]">
          Built by teams who've faced the chaos of prompt management.
        </p>
      </div>
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] p-6">
          <div class="h-12 w-12 rounded-lg bg-primary-100 dark:bg-primary-900/30 flex items-center justify-center mb-4">
            <svg class="h-6 w-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold">Compile-Time Resolution</h3>
          <p class="mt-2 text-[var(--color-text-muted)]">
            <code>if</code>, <code>case</code>, and <code>vary</code> blocks resolve before the LLM call. No branching logic reaches your model.
          </p>
        </div>
        <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] p-6">
          <div class="h-12 w-12 rounded-lg bg-primary-100 dark:bg-primary-900/30 flex items-center justify-center mb-4">
            <svg class="h-6 w-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold">Input & Output Contracts</h3>
          <p class="mt-2 text-[var(--color-text-muted)]">
            Declare params and response schemas. Both version together. Breaking changes are detected automatically.
          </p>
        </div>
        <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] p-6">
          <div class="h-12 w-12 rounded-lg bg-primary-100 dark:bg-primary-900/30 flex items-center justify-center mb-4">
            <svg class="h-6 w-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold">Fragment Composition</h3>
          <p class="mt-2 text-[var(--color-text-muted)]">
            Compose prompts from reusable fragments. Static fragments are cached. Dynamic fragments fetch fresh each request.
          </p>
        </div>
        <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] p-6">
          <div class="h-12 w-12 rounded-lg bg-primary-100 dark:bg-primary-900/30 flex items-center justify-center mb-4">
            <svg class="h-6 w-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold">Semantic Versioning</h3>
          <p class="mt-2 text-[var(--color-text-muted)]">
            Pin callers to major versions. Old versions are archived. Breaking changes require bumping the major version.
          </p>
        </div>
        <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] p-6">
          <div class="h-12 w-12 rounded-lg bg-primary-100 dark:bg-primary-900/30 flex items-center justify-center mb-4">
            <svg class="h-6 w-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold">Three Cache Layers</h3>
          <p class="mt-2 text-[var(--color-text-muted)]">
            Structural skeleton cached by compile-time params. Vary branches preloaded at startup. Fragment content cached by path.
          </p>
        </div>
        <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] p-6">
          <div class="h-12 w-12 rounded-lg bg-primary-100 dark:bg-primary-900/30 flex items-center justify-center mb-4">
            <svg class="h-6 w-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold">MCP Server</h3>
          <p class="mt-2 text-[var(--color-text-muted)]">
            Connect your LLM coding tools via MCP. Discover prompt schemas, params, and contracts without reading files.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl bg-gradient-to-br from-primary-600 to-purple-600 p-8 sm:p-12 text-center">
        <h2 class="text-3xl font-bold text-white">
          Ready to clean up your prompts?
        </h2>
        <p class="mt-4 text-lg text-primary-100">
          Start with a clean compile-to-LLM workflow today.
        </p>
        <div class="mt-8">
          <a href="/docs/getting-started" class="btn bg-white text-primary-600 hover:bg-primary-50">
            Get Started
          </a>
        </div>
      </div>
    </div>
  </section>
</MarketingLayout>
