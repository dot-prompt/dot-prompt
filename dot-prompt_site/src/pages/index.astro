---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import ComparisonBlock from '../components/ComparisonBlock.astro';
import SocialProof from '../components/SocialProof.astro';
import ProblemSection from '../components/ProblemSection.astro';
import WhoItsFor from '../components/WhoItsFor.astro';
import SolutionSteps from '../components/SolutionSteps.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import VisibilityDemo from '../components/VisibilityDemo.astro';
import BeforeAfter from '../components/BeforeAfter.astro';
import GettingStarted from '../components/GettingStarted.astro';
import FileFormat from '../components/FileFormat.astro';
import Pricing from '../components/Pricing.astro';
import Ecosystem from '../components/Ecosystem.astro';
import Testimonials from '../components/Testimonials.astro';
import FinalCTA from '../components/FinalCTA.astro';

const heroPrompt = `if @user_is_new is true do
  Welcome! Let's start with 
  the basics of how this works.
else
  Welcome back! Ready 
  to continue?
end @user_is_new`;

const heroBranches = [
  {
    label: "New User",
    params: [{ name: "user_is_new", value: "true" }],
    code: `Welcome! Let's start with
the basics of how this works.`
  },
  {
    label: "Returning User",
    params: [{ name: "user_is_new", value: "false" }],
    code: `Welcome back! Ready
to continue?`
  }
];
---

<MarketingLayout title="dot-prompt — See exactly what your AI receives">
  <!-- Hero Section -->
  <section class="pt-10  relative overflow-hidden">
    <!-- Indigo Glow -->
    <div class="absolute -top-[10%] -left-[10%] w-[40%] h-[40%] bg-[var(--color-accent)]/10 blur-[120px] rounded-full pointer-events-none"></div>
    <div class="absolute -bottom-[10%] -right-[10%] w-[30%] h-[30%] bg-[var(--color-accent)]/5 blur-[100px] rounded-full pointer-events-none"></div>

    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-4xl text-center mb-24">
        <span class="inline-block text-xs font-bold tracking-[0.3em] uppercase text-indigo-400/80 mb-8 px-5 py-2 rounded-full border border-indigo-500/20 bg-indigo-500/5 backdrop-blur-sm shadow-2xl shadow-indigo-500/10">
          Open the black box
        </span>
        <h1 class="text-4xl sm:text-7xl lg:text-8xl font-bold tracking-tight leading-[1.1] mb-12 italic px-4">
          Why does your AI <br/> <span class="text-gradient inline-block pr-4">say that?</span>
        </h1>
        <p class="mx-auto mt-8 text-xl sm:text-2xl text-[var(--color-text-muted)] leading-[1.6] max-w-3xl font-medium">
          dot-prompt shows you the exact instructions your AI receives — before they get there. <br class="hidden sm:block" /> 
          Write structured prompts, see the result instantly, and finally understand what's going on inside.
        </p>
        <div class="mt-16 flex flex-col sm:flex-row items-center justify-center gap-8">
          <a href="/docs/getting-started" class="btn btn-primary px-12 py-5 rounded-2xl text-2xl font-bold bg-[var(--color-accent)] hover:scale-[1.05] transition-transform shadow-2xl shadow-indigo-500/30 text-white">
            Get Started — it's free
          </a>
          <a href="https://github.com/dot-prompt/dot-prompt" target="_blank" class="px-12 py-5 rounded-2xl text-2xl font-bold border border-[var(--color-border)] hover:bg-[var(--color-surface)] transition-all flex items-center gap-3">
             <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12c0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
            View on GitHub
          </a>
        </div>
      </div>

       <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 hero-comparison-section">
            <div class="flex items-center justify-center gap-8 mb-6 text-[11px] font-bold uppercase tracking-[0.3em] text-indigo-400">
                <span class="opacity-40">Try it:</span>
                <button 
                  id="btn-new-user" 
                  class="px-4 py-2 rounded-lg bg-indigo-500/20 border border-indigo-500/30 text-indigo-100 transition-all hover:bg-indigo-500/30 active-tab"
                >
                  New User
                </button>
                <button 
                  id="btn-returning-user" 
                  class="px-4 py-2 rounded-lg bg-transparent border border-white/5 text-indigo-400/50 transition-all hover:border-indigo-500/20 hover:text-indigo-300"
                >
                  Returning User
                </button>
            </div>
            
            <div class="relative min-h-[400px]">
              <div id="branch-new-user" class="">
                <ComparisonBlock 
                    featureName="" 
                    description="" 
                    prompt={heroPrompt} 
                    branches={[heroBranches[0]]}
                    promptTitle="onboarding.prompt"
                />
              </div>
              <div id="branch-returning-user" class="absolute inset-0 hidden">
                <ComparisonBlock 
                    featureName="" 
                    description="" 
                    prompt={heroPrompt} 
                    branches={[heroBranches[1]]}
                    promptTitle="onboarding.prompt"
                />
              </div>
            </div>

            <div class="mt-8 text-center">
                 <span class="text-[10px] font-mono text-indigo-400 font-bold tracking-widest uppercase opacity-60">
                    47 lines &rarr; 3 lines &middot; 312 tokens
                 </span>
            </div>
       </div>
    </div>
  </section>

  <script>
    const btnNew = document.getElementById('btn-new-user');
    const btnReturning = document.getElementById('btn-returning-user');
    const branchNew = document.getElementById('branch-new-user');
    const branchReturning = document.getElementById('branch-returning-user');

    function showNew() {
      btnNew?.classList.add('active-tab', 'bg-indigo-500/20', 'border-indigo-500/30', 'text-indigo-100');
      btnReturning?.classList.remove('active-tab', 'bg-indigo-500/20', 'border-indigo-500/30', 'text-indigo-100');
      btnReturning?.classList.add('bg-transparent', 'border-white/5', 'text-indigo-400/50');

      branchNew?.classList.remove('hidden', 'absolute', 'inset-0');
      branchReturning?.classList.add('hidden', 'absolute', 'inset-0');
    }

    function showReturning() {
      btnReturning?.classList.add('active-tab', 'bg-indigo-500/20', 'border-indigo-500/30', 'text-indigo-100');
      btnReturning?.classList.remove('bg-transparent', 'border-white/5', 'text-indigo-400/50');
      
      btnNew?.classList.remove('active-tab', 'bg-indigo-500/20', 'border-indigo-500/30', 'text-indigo-100');
      btnNew?.classList.add('bg-transparent', 'border-white/5', 'text-indigo-400/50');

      branchReturning?.classList.remove('hidden', 'absolute', 'inset-0');
      branchNew?.classList.add('hidden', 'absolute', 'inset-0');
    }

    btnNew?.addEventListener('click', showNew);
    btnReturning?.addEventListener('click', showReturning);
  </script>

  <!-- Social Proof Bar -->
  <SocialProof />

  <!-- The Problem -->
  <ProblemSection />

  <!-- Who It's For -->
  <WhoItsFor />

  <!-- How It Works (Solution Steps) -->
  <SolutionSteps />

  <!-- Features Grid -->
  <FeatureGrid />

  <!-- Visibility Demo -->
  <VisibilityDemo />

  <!-- Before / After -->
  <BeforeAfter />

  <!-- Getting Started (Docker/Code) -->
  <GettingStarted />

  <!-- File Format Deep Dive -->
  <FileFormat />

  <!-- Pricing -->
  <Pricing />

  <!-- Ecosystem -->
  <Ecosystem />

  <!-- Testimonials -->
  <Testimonials />

  <!-- Final CTA -->
  <FinalCTA />

</MarketingLayout>

<style>
  .text-gradient {
    @apply bg-clip-text text-transparent bg-gradient-to-r from-indigo-400 via-indigo-200 to-indigo-500;
  }
</style>

