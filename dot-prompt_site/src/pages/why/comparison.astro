---
import MarketingLayout from '../../layouts/MarketingLayout.astro';

const comparisons = [
  {
    name: 'F-strings',
    icon: '🐍',
    pros: ['Built into Python', 'Simple for small prompts'],
    cons: ['No structure', 'No validation', 'No versioning', 'Scattered across code'],
    score: 2,
  },
  {
    name: 'YAML Config',
    icon: '📄',
    pros: ['Human-readable', 'Structure supported'],
    cons: ['No logic/branching', 'No compile-time resolution', 'No contracts', 'Limited tooling'],
    score: 3,
  },
  {
    name: 'Markdown',
    icon: '📝',
    pros: ['Simple', 'Universal', 'Good for documentation'],
    cons: ['No variables', 'No logic', 'No structure', 'Cannot compose'],
    score: 2,
  },
  {
    name: 'Jinja2',
    icon: '🎨',
    pros: ['Powerful templating', 'Wide adoption', 'Extensible'],
    cons: ['Runtime evaluation', 'No type system', 'No contracts', 'No versioning'],
    score: 4,
  },
  {
    name: '.prompt',
    icon: '⚡',
    pros: ['Compile-time resolution', 'Type system', 'Versioning', 'Contracts', 'Fragment composition'],
    cons: ['New syntax to learn'],
    score: 5,
  },
];
---

<MarketingLayout title="Comparison - Why .prompt">
  <section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <nav class="mb-8">
          <a href="/why" class="text-primary-600 hover:underline">&larr; Back to Why</a>
        </nav>
        <h1 class="text-4xl font-bold">How .prompt compares</h1>
        <p class="mt-4 text-xl text-[var(--color-text-muted)]">
          See how .prompt stacks up against the alternatives.
        </p>
      </div>
    </div>
  </section>

  <section class="py-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead>
              <tr class="border-b border-[var(--color-border)]">
                <th class="pb-4 text-left font-semibold">Feature</th>
                <th class="pb-4 text-center font-semibold">F-strings</th>
                <th class="pb-4 text-center font-semibold">YAML</th>
                <th class="pb-4 text-center font-semibold">Markdown</th>
                <th class="pb-4 text-center font-semibold">Jinja2</th>
                <th class="pb-4 text-center font-semibold text-primary-600">.prompt</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-[var(--color-border)]">
                <td class="py-4">Compile-time resolution</td>
                <td class="py-4 text-center">❌</td>
                <td class="py-4 text-center">❌</td>
                <td class="py-4 text-center">❌</td>
                <td class="py-4 text-center">❌</td>
                <td class="py-4 text-center text-primary-600">✅</td>
              </tr>
              <tr class="border-b border-[var(--color-border)]">
                <td class="py-4">Type system</td>
                <td class="py-4 text-center">❌</td>
                <td class="py-4 text-center">⚠️</td>
                <td class="py-4 text-center">❌</td>
                <td class="py-4 text-center">❌</td>
                <td class="py-4 text-center text-primary-600">✅</td>
              </tr>
              <tr class="border-b border-[var(--color-border)]">
                <td class="py-4">Input contracts</td>
                <td class="py-4 text-center">❌</td>
                <td class="py-4 text-center">❌</td>
                <td class="py-4 text-center">❌</td>
                <td class="py-4 text-center">❌</td>
                <td class="py-4 text-center text-primary-600">✅</td>
              </tr>
              <tr class="border-b border-[var(--color-border)]">
                <td class="py-4">Output contracts</td>
                <td class="py-4 text-center">❌</td>
                <td class="py-4 text-center">❌</td>
                <td class="py-4 text-center">❌</td>
                <td class="py-4 text-center">❌</td>
                <td class="py-4 text-center text-primary-600">✅</td>
              </tr>
              <tr class="border-b border-[var(--color-border)]">
                <td class="py-4">Versioning</td>
                <td class="py-4 text-center">❌</td>
                <td class="py-4 text-center">❌</td>
                <td class="py-4 text-center">❌</td>
                <td class="py-4 text-center">❌</td>
                <td class="py-4 text-center text-primary-600">✅</td>
              </tr>
              <tr class="border-b border-[var(--color-border)]">
                <td class="py-4">Fragment composition</td>
                <td class="py-4 text-center">⚠️</td>
                <td class="py-4 text-center">⚠️</td>
                <td class="py-4 text-center">❌</td>
                <td class="py-4 text-center">✅</td>
                <td class="py-4 text-center text-primary-600">✅</td>
              </tr>
              <tr>
                <td class="py-4">Breaking change detection</td>
                <td class="py-4 text-center">❌</td>
                <td class="py-4 text-center">❌</td>
                <td class="py-4 text-center">❌</td>
                <td class="py-4 text-center">❌</td>
                <td class="py-4 text-center text-primary-600">✅</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-[var(--color-surface)]">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <h2 class="text-2xl font-bold mb-8 text-center">Summary</h2>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {comparisons.map((item) => (
            <div class:list={[
              'rounded-xl border p-6',
              item.name === '.prompt' ? 'border-primary-500 bg-primary-50 dark:bg-primary-900/20' : 'border-[var(--color-border)] bg-[var(--color-bg)]'
            ]}>
              <div class="flex items-center gap-3 mb-4">
                <span class="text-2xl">{item.icon}</span>
                <h3 class="font-semibold">{item.name}</h3>
              </div>
              <div class="mb-4">
                <div class="flex gap-1">
                  {[1, 2, 3, 4, 5].map((n) => (
                    <div class:list={[
                      'h-2 flex-1 rounded-full',
                      n <= item.score ? (item.name === '.prompt' ? 'bg-primary-500' : 'bg-primary-500/40') : 'bg-[var(--color-border)]'
                    ]}></div>
                  ))}
                </div>
              </div>
              <div class="space-y-2">
                {item.pros.map((pro) => (
                  <p class="text-sm text-green-600 dark:text-green-400">+ {pro}</p>
                ))}
                {item.cons.map((con) => (
                  <p class="text-sm text-[var(--color-text-muted)]">- {con}</p>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-lg">
          .prompt is purpose-built for prompt engineering. It brings the discipline of software engineering to your prompts.
        </p>
        <div class="mt-8">
          <a href="/docs/getting-started" class="btn btn-primary">
            Get Started
          </a>
        </div>
      </div>
    </div>
  </section>
</MarketingLayout>
