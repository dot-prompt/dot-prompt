---
import MarketingLayout from '../../layouts/MarketingLayout.astro';

const useCases = [
  {
    title: 'Educational Prompts',
    description: 'Build adaptive teaching experiences that adjust to learner level and progress.',
    href: '/use-cases/educational-prompts',
    icon: '🎓',
  },
  {
    title: 'Multi-Step Workflows',
    description: 'Orchestrate complex multi-turn conversations with clear state management.',
    href: '/use-cases/multi-step-workflows',
    icon: '🔄',
  },
  {
    title: 'Conditional Generation',
    description: 'Generate contextually appropriate responses based on user attributes.',
    href: '/use-cases/conditional-generation',
    icon: '🔀',
  },
  {
    title: 'Fragment Composition',
    description: 'Build prompts from reusable, composable pieces.',
    href: '/use-cases/fragment-composition',
    icon: '🧩',
  },
];
---

<MarketingLayout title="Use Cases - dot-prompt">
  <section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h1 class="text-4xl font-bold">Use Cases</h1>
        <p class="mt-4 text-xl text-[var(--color-text-muted)]">
          Real-world examples of how teams use .prompt to build better LLM applications.
        </p>
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 md:grid-cols-2">
        {useCases.map((useCase) => (
          <a
            href={useCase.href}
            class="group rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-8 hover:border-primary-500 transition-all"
          >
            <div class="text-4xl mb-4">{useCase.icon}</div>
            <h2 class="text-xl font-semibold group-hover:text-primary-600 transition-colors">
              {useCase.title}
            </h2>
            <p class="mt-2 text-[var(--color-text-muted)]">
              {useCase.description}
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-[var(--color-surface)]">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-2xl font-bold">Have a use case to share?</h2>
        <p class="mt-4 text-[var(--color-text-muted)]">
          We'd love to hear how you're using .prompt. Share your story and help others learn.
        </p>
        <div class="mt-8">
          <a
            href="https://github.com/dot-prompt/dot-prompt/discussions"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-primary"
          >
            Share Your Story
          </a>
        </div>
      </div>
    </div>
  </section>
</MarketingLayout>
