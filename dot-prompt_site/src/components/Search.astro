---
const searchContent = [
  { title: 'Getting Started', url: '/docs/getting-started', description: 'Learn how to set up and use .prompt' },
  { title: 'Language Reference', url: '/docs/language-reference', description: 'Complete syntax and features' },
  { title: 'Types', url: '/docs/types', description: 'Type system documentation' },
  { title: 'Control Flow', url: '/docs/control-flow', description: 'if/elif/else, case, vary blocks' },
  { title: 'Fragments', url: '/docs/fragments', description: 'Static and dynamic fragments' },
  { title: 'Response Contracts', url: '/docs/response-contracts', description: 'Output schema definition' },
  { title: 'Versioning', url: '/docs/versioning', description: 'Semantic versioning for prompts' },
  { title: 'Why .prompt', url: '/why', description: 'Why use a compiled language for prompts' },
  { title: 'The Problem', url: '/why/the-problem', description: 'Challenges with prompt management' },
  { title: 'The Solution', url: '/why/the-solution', description: 'How .prompt solves these problems' },
  { title: 'Use Cases', url: '/use-cases', description: 'Real-world use cases and examples' },
  { title: 'Educational Prompts', url: '/use-cases/educational-prompts', description: 'Teaching and learning applications' },
];
---

<div class="relative">
  <button
    id="search-button"
    type="button"
    class="flex items-center gap-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-1.5 text-sm text-[var(--color-text-muted)] hover:border-primary-500 transition-colors"
  >
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
    </svg>
    <span class="hidden sm:inline">Search...</span>
    <kbd class="hidden sm:inline-flex items-center gap-0.5 rounded border border-[var(--color-border)] bg-[var(--color-bg)] px-1.5 py-0.5 text-xs font-mono">
      <span class="text-xs">⌘</span>K
    </kbd>
  </button>

  <div
    id="search-modal"
    class="fixed inset-0 z-50 hidden bg-black/50 backdrop-blur-sm"
  >
    <div class="fixed left-1/2 top-1/4 w-full max-w-2xl -translate-x-1/2 px-4">
      <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] shadow-2xl">
        <div class="flex items-center gap-3 border-b border-[var(--color-border)] px-4">
          <svg class="h-5 w-5 text-[var(--color-text-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input
            id="search-input"
            type="text"
            placeholder="Search documentation..."
            class="flex-1 bg-transparent py-4 text-[var(--color-text)] placeholder-[var(--color-text-muted)] focus:outline-none"
          />
          <kbd class="rounded border border-[var(--color-border)] bg-[var(--color-surface)] px-2 py-1 text-xs text-[var(--color-text-muted)]">
            ESC
          </kbd>
        </div>
        <div id="search-results" class="max-h-96 overflow-y-auto p-2">
          <div class="text-center py-8 text-[var(--color-text-muted)]">
            Start typing to search...
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script is:inline define:vars={{ searchContent }}>
  const searchButton = document.getElementById('search-button');
  const searchModal = document.getElementById('search-modal');
  const searchInput = document.getElementById('search-input');
  const searchResults = document.getElementById('search-results');

  function openSearch() {
    searchModal.classList.remove('hidden');
    searchInput.focus();
  }

  function closeSearch() {
    searchModal.classList.add('hidden');
    searchInput.value = '';
    searchResults.innerHTML = '<div class="text-center py-8 text-[var(--color-text-muted)]">Start typing to search...</div>';
  }

  searchButton.addEventListener('click', openSearch);

  searchModal.addEventListener('click', (e) => {
    if (e.target === searchModal) {
      closeSearch();
    }
  });

  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      openSearch();
    }
    if (e.key === 'Escape') {
      closeSearch();
    }
  });

  searchInput.addEventListener('input', (e) => {
    const query = e.target.value.toLowerCase().trim();
    
    if (!query) {
      searchResults.innerHTML = '<div class="text-center py-8 text-[var(--color-text-muted)]">Start typing to search...</div>';
      return;
    }

    const results = searchContent.filter(item => 
      item.title.toLowerCase().includes(query) || 
      item.description.toLowerCase().includes(query)
    );

    if (results.length === 0) {
      searchResults.innerHTML = '<div class="text-center py-8 text-[var(--color-text-muted)]">No results found</div>';
      return;
    }

    searchResults.innerHTML = results.map(item => `
      <a href="${item.url}" class="block rounded-lg p-3 hover:bg-[var(--color-surface)] transition-colors">
        <div class="font-medium text-[var(--color-text)]">${item.title}</div>
        <div class="text-sm text-[var(--color-text-muted)]">${item.description}</div>
      </a>
    `).join('');
  });
</script>
