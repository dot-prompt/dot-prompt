---
const currentYear = new Date().getFullYear();

const columns = [
  {
    title: 'Product',
    links: [
      { href: '/docs', label: 'Docs' },
      { href: 'https://github.com/dot-prompt/dot-prompt', label: 'GitHub' },
      { href: '/changelog', label: 'Changelog' },
      { href: '/roadmap', label: 'Roadmap' },
    ]
  },
  {
    title: 'Language',
    links: [
      { href: 'https://github.com/dot-prompt/spec', label: 'Specification' },
      { href: '/docs/language-reference', label: '.prompt syntax' },
      { href: '/docs/collections', label: 'Collections' },
      { href: '/docs/contracts', label: 'Contracts' },
    ]
  },
  {
    title: 'Community',
    links: [
      { href: '#', label: 'Discord' },
      { href: '#', label: 'Twitter / X' },
      { href: '#', label: 'HN thread' },
    ]
  },
  {
    title: 'Legal',
    links: [
      { href: '/license', label: 'License (Apache 2.0)' },
      { href: '/privacy', label: 'Privacy' },
    ]
  }
];
---

<footer class="border-t border-[var(--color-border)]/50 bg-[var(--color-bg)] pt-24 pb-12">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-12 mb-24">
      <div class="col-span-2 lg:col-span-1">
        <div class="flex items-center gap-2 mb-6">
          <span class="text-xl font-black tracking-tighter">.prompt</span>
        </div>
        <p class="text-sm text-[var(--color-text-muted)] leading-relaxed max-w-[200px]">
          See exactly what your AI receives.
        </p>
      </div>

      {columns.map(col => (
        <div>
          <h4 class="text-xs font-bold uppercase tracking-widest text-indigo-400 mb-6">{col.title}</h4>
          <ul class="space-y-4">
            {col.links.map(link => (
              <li>
                <a href={link.href} class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="pt-12 border-t border-[var(--color-border)]/50 flex flex-col md:flex-row justify-between items-center gap-8">
      <p class="text-xs text-[var(--color-text-muted)] font-bold tracking-widest uppercase opacity-60">
        &copy; 2026 dot-prompt &middot; Apache 2.0 &middot; Built in public
      </p>
      <div class="flex gap-8">
         <div class="h-4 w-4 bg-indigo-500/20 rounded-full blur-[1px]"></div>
         <div class="h-4 w-4 bg-indigo-500/10 rounded-full blur-[1px]"></div>
         <div class="h-4 w-4 bg-indigo-500/5 rounded-full blur-[1px]"></div>
      </div>
    </div>
  </div>
</footer>
