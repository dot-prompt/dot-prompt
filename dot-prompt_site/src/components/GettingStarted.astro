---
import CodeBlock from './CodeBlock.astro';

const dockerCode = `services:
  dot-prompt:
    image: dotprompt/server
    ports:
      - "4040:4040"  # viewer
      - "4041:4041"  # API
    volumes:
      - .:/app/repo
    environment:
      - REPO_PATH=/app/repo
      - PROMPTS_PATH=/app/repo/priv/prompts`;

const pythonCode = `# Terminal
pip install dot-prompt

# Python Code
from dot_prompt import Client

client = Client("http://localhost:4041")

result = client.render(
    "my_prompt",
    params={"user_level": "intermediate"},
    runtime={"user_input": "Hello"}
)

result["prompt"]             # send to your LLM
result["response_contract"]  # validate the response`;

const curlCode = `curl -X POST http://localhost:4041/api/render \\
  -H "Content-Type: application/json" \\
  -d '{
    "prompt": "my_prompt",
    "params": {"user_level": "intermediate"},
    "runtime": {"user_input": "Hello"}
  }'`;
---
<section class="py-32 border-t border-[var(--color-border)]/50 relative overflow-hidden bg-[var(--color-surface)]/10">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 mb-24 text-center">
    <span class="text-xs font-bold uppercase tracking-[0.2em] text-indigo-400 mb-8 block">Get started</span>
    <h2 class="text-4xl sm:text-6xl font-bold tracking-tight mb-8">
      Up and running <br/> <span class="text-gradient">in minutes.</span>
    </h2>
  </div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 space-y-24">
    {/* Step 1: Docker */}
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">
      <div class="max-w-md">
        <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-indigo-400 mb-4 block">Step 1</span>
        <h3 class="text-3xl font-bold mb-6 italic">Start dot-prompt</h3>
        <p class="text-[var(--color-text-muted)] text-lg leading-relaxed font-medium mb-8">
          Add this <code class="text-xs font-mono bg-indigo-500/10 px-1.5 py-0.5 rounded">docker-compose.yml</code> to your project root and run one command.
        </p>
        <div class="p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)]/80">
          <code class="text-xs text-indigo-300 font-mono">docker compose up</code>
        </div>
        <p class="mt-8 text-sm text-[var(--color-text-muted)] font-bold italic border-l-2 border-indigo-500/20 pl-6">
          Then open <span class="text-indigo-400 underline decoration-indigo-500/30">localhost:4040</span> — your viewer is running.
        </p>
      </div>
      <div class="relative group">
        <div class="absolute -inset-4 bg-indigo-500/10 rounded-2xl blur-xl opacity-0 group-hover:opacity-100 transition duration-500"></div>
        <div class="relative rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)]/80 p-2 overflow-hidden shadow-2xl">
           <CodeBlock code={dockerCode} language="yaml" />
        </div>
      </div>
    </div>

    {/* Step 2: API */}
    <div class="relative rounded-3xl border border-[var(--color-border)] bg-[var(--color-bg)] p-12 overflow-hidden shadow-2xl">
       <div class="absolute top-0 right-0 w-1/2 h-full bg-indigo-500/5 blur-[120px] pointer-events-none"></div>
       <div class="max-w-3xl mb-12">
          <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-indigo-400 mb-4 block">Step 2</span>
          <h3 class="text-3xl font-bold mb-6 italic">Call the API</h3>
          <p class="text-[var(--color-text-muted)] text-lg leading-relaxed font-medium">
             Pick your language. dot-prompt works with any language via the container HTTP API or native libraries.
          </p>
       </div>

       <div class="grid lg:grid-cols-12 gap-12">
          <div class="lg:col-span-8">
             <div class="mb-4 flex items-center gap-4">
                <span class="text-xs font-bold text-indigo-400 uppercase tracking-widest">Python</span>
                <div class="h-px flex-1 bg-indigo-500/20"></div>
             </div>
             <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] p-2">
                <CodeBlock code={pythonCode} language="python" />
             </div>
          </div>
          <div class="lg:col-span-4">
             <div class="mb-4 flex items-center gap-4">
                <span class="text-xs font-bold text-[var(--color-text-muted)] uppercase tracking-widest">HTTP</span>
                <div class="h-px flex-1 bg-[var(--color-border)]/50"></div>
             </div>
             <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] p-2 opacity-80">
                <CodeBlock code={curlCode} language="bash" />
             </div>
          </div>
       </div>
    </div>
  </div>
</section>

<style>
  .text-gradient {
    @apply bg-clip-text text-transparent bg-gradient-to-r from-indigo-400 to-indigo-600;
  }
</style>
