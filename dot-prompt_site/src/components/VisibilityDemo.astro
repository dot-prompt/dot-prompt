---
import CodeBlock from './CodeBlock.astro';

const leftCode = `... 47 lines of complex branching logic ...
if @user_status is high_value do
  [include: "offers/vip"]
else if @user_is_new and @country == 'US' do
  [include: "offers/onboarding_us"]
else
  [include: "offers/generic"]
end`;

const rightCode = `Welcome back, Alice!

Check out our latest VIP member 
offers exclusively for you.`;
---
<section class="py-32 border-t border-[var(--color-border)]/50 relative bg-[var(--color-surface)]/10 overflow-hidden">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center mb-20">
    <span class="text-xs font-bold uppercase tracking-[0.2em] text-indigo-400 mb-8 block">See the difference</span>
    <h2 class="text-4xl sm:text-6xl font-bold tracking-tight mb-8">
      This is what your <br/> <span class="text-gradient">AI actually receives.</span>
    </h2>
  </div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 grid lg:grid-cols-2 gap-12 items-start">
    <div class="space-y-4">
      <div class="flex items-center gap-2 mb-2">
        <span class="text-[10px] font-mono uppercase tracking-[0.2em] text-indigo-400 opacity-70">Your prompt file — 47 lines</span>
        <div class="h-px flex-1 bg-gradient-to-r from-indigo-500/20 to-transparent"></div>
      </div>
      <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)]/80 p-2 overflow-hidden opacity-60">
        <CodeBlock code={leftCode} language="dotprompt" />
      </div>
    </div>

    <div class="relative group">
      <div class="absolute -inset-4 bg-indigo-500/10 rounded-2xl blur-2xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
      <div class="space-y-4">
        <div class="flex items-center gap-2 mb-2">
          <span class="text-[10px] font-mono uppercase tracking-[0.2em] text-emerald-400 opacity-70">What your AI receives — 3 lines</span>
          <div class="h-px flex-1 bg-gradient-to-r from-emerald-500/20 to-transparent"></div>
        </div>
        <div class="rounded-xl border border-emerald-500/20 bg-emerald-500/5 p-8 relative overflow-hidden backdrop-blur-xl">
           <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/5 to-transparent"></div>
           <p class="text-2xl font-bold text-emerald-100 leading-relaxed relative z-10">
             Welcome back, Alice!<br/><br/>
             Check out our latest VIP member offers exclusively for you.
           </p>
           <div class="mt-8 flex items-center gap-2 text-[10px] font-bold text-emerald-400/70 tracking-widest uppercase relative z-10">
             <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
             Compilation Successful · 312 Tokens
           </div>
        </div>
      </div>
    </div>
  </div>

  <div class="mx-auto max-w-2xl px-4 mt-16 text-center">
    <p class="text-lg text-[var(--color-text-muted)] font-medium leading-relaxed italic border-l-2 border-indigo-500/20 pl-8 inline-block text-left">
      "Every branch resolved. Every variable filled. Every token accounted for. This is what dot-prompt shows you."
    </p>
    <p class="mt-4 text-xs font-bold uppercase tracking-widest text-indigo-400/60">
      Change the params — the output changes instantly.
    </p>
  </div>
</section>

<style>
  .text-gradient {
    @apply bg-clip-text text-transparent bg-gradient-to-r from-indigo-400 to-indigo-600;
  }
</style>
