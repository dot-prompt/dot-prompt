---
import { codeToHtml } from 'shiki';

interface Props {
  code: string;
  language?: string;
  title?: string;
  showLineNumbers?: boolean;
}

const { code, language = 'elixir', title, showLineNumbers = false } = Astro.props;

let html: string;

if (language === 'dotprompt') {
  const tokens = highlightDotPrompt(code);
  html = `<pre class="astro-code">${tokens}</pre>`;
} else {
  html = await codeToHtml(code, {
    lang: language,
    themes: {
      light: 'github-light',
      dark: 'github-dark',
    },
    defaultColor: 'light',
  });
}

function highlightDotPrompt(code: string): string {
  const lines = code.split('\n');
  return lines.map(line => {
    let highlighted = escapeHtml(line);
    
    // Keywords: case, end, init, response, def, params, vary, if, do
    highlighted = highlighted.replace(/\b(case|end|init|response|def|params|vary|if|do)\b/g, '<span class="token-keyword">$1</span>');
    
    // Case labels: word before colon (e.g., "analogy:" "recognition:")
    highlighted = highlighted.replace(/^(\s*)(\w+)(:)/gm, '$1<span class="token-label">$2</span>$3');
    
    highlighted = highlighted.replace(/(@\w+)/g, '<span class="token-variable">$1</span>');
    
    highlighted = highlighted.replace(/\b(true|false)\b/g, '<span class="token-boolean">$1</span>');
    
    highlighted = highlighted.replace(/(#.*)$/g, '<span class="token-comment">$1</span>');
    
    highlighted = highlighted.replace(/(\{\{[^}]+\}\})/g, '<span class="token-interpolation">$1</span>');
    
    highlighted = highlighted.replace(/(\{[^}]+\})/g, '<span class="token-braces">$1</span>');
    
    return `<code>${highlighted}</code>`;
  }).join('\n');
}

function escapeHtml(str: string): string {
  return str
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;');
}
---

<div class="group relative my-6">
  {title && (
    <div class="border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-2 text-xs font-mono text-[var(--color-text-muted)] uppercase tracking-wide">
      {title}
    </div>
  )}
  <div class="relative">
    <div class:list={[
      'overflow-x-auto border border-t-0 border-[var(--color-border)] [&>pre]:m-0 [&>pre]:overflow-x-auto [&>pre]:text-sm [&>pre]:font-mono',
      title ? '' : '[&>div]:rounded-none'
    ]}>
      <div set:html={html} />
    </div>
    <button
      class="copy-button absolute right-2 top-2 bg-[var(--color-surface)] px-2 py-1 text-xs text-[var(--color-text-muted)] opacity-0 transition-opacity hover:bg-[var(--color-border)] group-hover:opacity-100"
      aria-label="Copy code"
    >
      Copy
    </button>
  </div>
</div>

<script>
  document.querySelectorAll('.copy-button').forEach((button) => {
    button.addEventListener('click', async () => {
      const codeBlock = button.closest('.group')?.querySelector('pre code');
      if (codeBlock) {
        await navigator.clipboard.writeText(codeBlock.textContent || '');
        button.textContent = 'Copied!';
        setTimeout(() => {
          button.textContent = 'Copy';
        }, 2000);
      }
    });
  });
</script>

<style is:global>
  /* Basic Code Block Reset */
  pre.shiki,
  pre.astro-code {
    white-space: pre-wrap !important;
    word-break: break-word !important;
    overflow-wrap: anywhere !important;
    display: block !important;
    margin: 0 !important;
    padding: 1.5rem !important;
    background-color: transparent !important;
  }

  /* DotPrompt base text color & Fallback for Shiki tokens */
  pre.astro-code,
  pre.astro-code code,
  pre.astro-code span:not([class^="token-"]),
  pre.shiki,
  pre.shiki code,
  pre.shiki span:not([class^="token-"]) {
    background-color: transparent !important;
    color: var(--color-text) !important;
  }
  
  /* Reset Shiki defaults that might interfere */
  pre.shiki {
    background-color: transparent !important;
  }

  /* DotPrompt custom highlighting - Indigo Theme */
  /* Using higher specificity to ensure victory over Shiki inline styles */
  .astro-code .token-keyword, .shiki .token-keyword {
    color: #818CF8 !important; /* Indigo 400 */
    font-weight: 600;
  }
  .astro-code .token-label, .shiki .token-label {
    color: #2DD4BF !important; /* Teal 400 */
    font-weight: 500;
  }
  .astro-code .token-variable, .shiki .token-variable {
    color: #FDBA74 !important; /* Orange 300 */
    font-weight: 500;
  }
  .astro-code .token-boolean, .shiki .token-boolean {
    color: #34D399 !important; /* Emerald 400 */
  }
  .astro-code .token-comment, .shiki .token-comment {
    color: #636370 !important; /* Muted warm */
    font-style: italic;
  }
  .astro-code .token-interpolation, .shiki .token-interpolation {
    color: #F472B6 !important; /* Pink 400 */
    font-weight: 500;
  }
  .astro-code .token-braces, .shiki .token-braces {
    color: #818CF8 !important;
    opacity: 0.8;
  }

  /* Ensure consistent spacing and wrapping */
  pre.astro-code, pre.shiki {
    padding: 1.5rem !important;
    margin: 0 !important;
    font-size: 0.875rem !important;
    line-height: 1.7 !important;
  }
</style>