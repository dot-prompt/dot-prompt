---
---
<section class="py-48 border-t border-[var(--color-border)]/50 relative overflow-hidden bg-[var(--color-surface)]/20">
  <div class="absolute inset-0 bg-gradient-to-br from-indigo-500/5 to-transparent"></div>
  
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center relative z-10">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-5xl sm:text-7xl lg:text-8xl font-bold tracking-tight mb-12 italic text-gradient leading-tight inline-block px-8 py-2">
        Open the <br/> black box.
      </h2>
      <p class="text-xl sm:text-2xl text-[var(--color-text-muted)] mb-16 font-medium leading-relaxed max-w-2xl mx-auto">
        See exactly what your AI receives. Understand exactly why it responds the way it does.
      </p>
      
      <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
        <a href="/docs/getting-started" class="btn btn-primary px-12 py-5 rounded-xl text-2xl font-bold bg-indigo-500 shadow-2xl shadow-indigo-500/40 hover:scale-[1.05] transition-transform text-white">
          Get Started — it's free
        </a>
        <a href="https://github.com/dot-prompt/dot-prompt" target="_blank" class="px-12 py-5 rounded-xl text-2xl font-bold border border-indigo-500/20 hover:bg-indigo-500/10 transition-colors">
          View on GitHub
        </a>
      </div>
      
      <div class="mt-16 flex items-center justify-center gap-8 text-[10px] font-bold uppercase tracking-[0.3em] text-indigo-400/50">
        <span>Apache 2.0 Open Source</span>
        <span>No Account Required</span>
        <span>Runs Locally</span>
      </div>
    </div>
  </div>
</section>

<style>
  .text-gradient {
    @apply bg-clip-text text-transparent bg-gradient-to-r from-indigo-400 to-indigo-600;
  }
</style>
