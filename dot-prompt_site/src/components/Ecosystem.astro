---
const cardClasses = "p-8 rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)]/10 hover:border-indigo-500/30 transition-all duration-300 group shadow-lg shadow-black/20 backdrop-blur-sm";
---
<section class="py-32 border-t border-[var(--color-border)]/50 relative overflow-hidden">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 mb-24">
    <div class="max-w-3xl">
      <span class="text-xs font-bold uppercase tracking-[0.2em] text-indigo-400 mb-8 block">Ecosystem</span>
      <h2 class="text-4xl sm:text-6xl font-bold tracking-tight mb-8">
        One language. <br/> <span class="text-gradient">Every tool.</span>
      </h2>
    </div>
  </div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 grid md:grid-cols-2 lg:grid-cols-3 gap-12">
    {/* VS Code */}
    <div class={cardClasses}>
       <div class="w-10 h-10 rounded-lg bg-indigo-500/10 flex items-center justify-center text-indigo-400 mb-6 group-hover:scale-110 transition-transform">
         <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 17v-4l-3-3H5l-3 3v4a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2Z"/><path d="M19 13V9a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v4"/><path d="M15 7V5a2 2 0 0 0-2-2h-2a2 2 0 0 0-2 2v2"/></svg>
       </div>
       <h3 class="text-xl font-bold mb-4">VS Code extension</h3>
       <p class="text-[var(--color-text-muted)] font-medium leading-relaxed">
         Syntax highlighting, inline diagnostics, and breaking change notifications — right in your editor. Works whether you're writing or reviewing what an AI agent just wrote.
       </p>
    </div>

    {/* MCP */}
    <div class={cardClasses}>
       <div class="w-10 h-10 rounded-lg bg-indigo-500/10 flex items-center justify-center text-indigo-400 mb-6 group-hover:scale-110 transition-transform">
         <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 3v18"/><path d="m14 8 2 2-2 2"/><path d="m19 12-2-2 2-2"/></svg>
       </div>
       <h3 class="text-xl font-bold mb-4">MCP server</h3>
       <p class="text-[var(--color-text-muted)] font-medium leading-relaxed">
         Connect your AI coding tool to dot-prompt. It discovers your prompt schemas, understands your contracts, and writes `.prompt` files correctly without reading documentation.
       </p>
    </div>

    {/* Clients */}
    <div class={cardClasses}>
       <div class="w-10 h-10 rounded-lg bg-indigo-500/10 flex items-center justify-center text-indigo-400 mb-6 group-hover:scale-110 transition-transform">
         <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
       </div>
       <h3 class="text-xl font-bold mb-4">Native Client Libs</h3>
       <div class="space-y-4">
          <div class="flex items-center gap-3">
             <span class="w-1.5 h-1.5 rounded-full bg-indigo-500"></span>
             <p class="text-[var(--color-text-muted)] font-bold">Python Client &rarr; <span class="text-indigo-400 font-mono text-xs">pip install dot-prompt</span></p>
          </div>
          <div class="flex items-center gap-3 opacity-50 italic">
             <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-text-muted)]"></span>
             <p class="text-[var(--color-text-muted)]">TypeScript Client &rarr; <span class="font-mono text-xs">npm install @dot-prompt/sdk</span></p>
          </div>
       </div>
    </div>

    {/* Spec */}
    <div class={`${cardClasses} lg:col-span-3`}>
       <div class="max-w-2xl px-8 py-4">
          <h3 class="text-3xl font-bold mb-4">Language specification</h3>
          <p class="text-lg text-[var(--color-text-muted)] font-medium leading-relaxed">
            dot-prompt is an open language specification. Any tool can implement it. Any language can support it. The spec lives at <a href="https://github.com/dot-prompt/spec" class="text-indigo-400 font-mono hover:underline">github.com/dot-prompt/spec</a>.
          </p>
       </div>
    </div>
  </div>
</section>

<style>
  .text-gradient {
    @apply bg-clip-text text-transparent bg-gradient-to-r from-indigo-400 to-indigo-600;
  }
</style>
