---
import CodeBlock from './CodeBlock.astro';

const step1Code = `if @user_is_new is true do
  Welcome! Let's start with the basics.
else
  Welcome back. Ready to continue?
end @user_is_new`;
---
<section class="py-32 border-t border-[var(--color-border)]/50 relative overflow-hidden bg-[var(--color-surface)]/10">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-24 text-center max-w-3xl mx-auto">
      <span class="text-xs font-bold uppercase tracking-[0.2em] text-indigo-400 mb-8 block">How it works</span>
      <h2 class="text-4xl sm:text-6xl font-bold tracking-tight mb-8">
        Write once. <br/> <span class="text-gradient">See everything.</span>
      </h2>
    </div>

    <div class="space-y-48">
      {/* Step 1: Write */}
      <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">
        <div>
          <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-indigo-400 mb-4 block px-3 py-1 rounded bg-indigo-500/10 w-fit">Step 1 — Write</span>
          <h3 class="text-3xl font-bold mb-6">Keep your prompts in readable files</h3>
          <p class="text-[var(--color-text-muted)] text-lg leading-relaxed font-medium mb-8">
            Write your prompts in <code class="text-indigo-300 font-mono bg-indigo-500/10 px-1.5 py-0.5 rounded">.prompt</code> files — structured, readable, and separate from your code. Add branching logic, variables, and variations. Your whole team can open them.
          </p>
        </div>
        <div class="relative group">
          <div class="absolute -inset-4 bg-gradient-to-r from-indigo-500/10 to-transparent rounded-2xl blur-xl opacity-0 group-hover:opacity-100 transition duration-500"></div>
          <div class="relative rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg)]/80 p-2 shadow-2xl overflow-hidden">
            <div class="flex items-center gap-2 px-6 py-4 border-b border-[var(--color-border)]/50 bg-[var(--color-surface)]/40">
              <span class="text-[10px] font-mono text-[var(--color-text-muted)] tracking-widest uppercase">onboarding.prompt</span>
            </div>
            <CodeBlock code={step1Code} language="dotprompt" />
          </div>
        </div>
      </div>

      {/* Step 2: See */}
      <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">
        <div class="lg:order-last">
          <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-indigo-400 mb-4 block px-3 py-1 rounded bg-indigo-500/10 w-fit">Step 2 — See</span>
          <h3 class="text-3xl font-bold mb-6">Watch your prompt compile in real time</h3>
          <p class="text-[var(--color-text-muted)] text-lg leading-relaxed font-medium mb-8">
            Open the dot-prompt viewer. Select your variables. Watch the exact output appear — the precise text your AI will receive. Change a variable. Watch it update instantly.
          </p>
        </div>
        <div class="relative p-12 rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)]/20 backdrop-blur-sm group hover:border-indigo-500/30">
          <div class="space-y-6">
             <div class="flex items-center gap-4 border-b border-[var(--color-border)] pb-8">
               <span class="text-xs font-bold text-[var(--color-text-muted)] uppercase tracking-widest">Select Variable</span>
               <div class="flex gap-2">
                 <button id="step2-btn-new" class="px-3 py-1.5 rounded-md bg-indigo-500/10 border border-indigo-500/20 text-[10px] font-bold text-indigo-300 uppercase tracking-widest">New User</button>
                 <button id="step2-btn-returning" class="px-3 py-1.5 rounded-md bg-[var(--color-bg)] border border-[var(--color-border)] text-[10px] font-bold text-[var(--color-text-muted)] uppercase tracking-widest opacity-50">Returning User</button>
               </div>
             </div>
             <div class="flex items-center gap-2 mb-4">
                <span class="text-[10px] font-mono uppercase tracking-[0.2em] text-[var(--color-text-muted)] opacity-70">What your AI receives</span>
                <div class="h-px flex-1 bg-gradient-to-r from-[var(--color-border)] to-transparent opacity-50"></div>
             </div>
             <div class="min-h-[120px]">
               <div id="step2-text-new" class="">
                 <p class="text-2xl font-bold text-indigo-200/90 leading-snug">
                   Welcome! Let's start with the basics of how this works.
                 </p>
               </div>
               <div id="step2-text-returning" class="hidden">
                 <p class="text-2xl font-bold text-indigo-200/90 leading-snug">
                   Welcome back. Ready to continue?
                 </p>
               </div>
             </div>
          </div>
        </div>
      </div>

<script>
  const btnNew = document.getElementById('step2-btn-new');
  const btnReturning = document.getElementById('step2-btn-returning');
  const textNew = document.getElementById('step2-text-new');
  const textReturning = document.getElementById('step2-text-returning');

  function showNew() {
    btnNew?.classList.add('bg-indigo-500/10', 'border-indigo-500/20', 'text-indigo-300');
    btnNew?.classList.remove('bg-[var(--color-bg)]', 'border-[var(--color-border)]', 'text-[var(--color-text-muted)]', 'opacity-50');
    
    btnReturning?.classList.add('bg-[var(--color-bg)]', 'border-[var(--color-border)]', 'text-[var(--color-text-muted)]', 'opacity-50');
    btnReturning?.classList.remove('bg-indigo-500/10', 'border-indigo-500/20', 'text-indigo-300');

    textNew?.classList.remove('hidden');
    textReturning?.classList.add('hidden');
  }

  function showReturning() {
    btnReturning?.classList.add('bg-indigo-500/10', 'border-indigo-500/20', 'text-indigo-300');
    btnReturning?.classList.remove('bg-[var(--color-bg)]', 'border-[var(--color-border)]', 'text-[var(--color-text-muted)]', 'opacity-50');
    
    btnNew?.classList.add('bg-[var(--color-bg)]', 'border-[var(--color-border)]', 'text-[var(--color-text-muted)]', 'opacity-50');
    btnNew?.classList.remove('bg-indigo-500/10', 'border-indigo-500/20', 'text-indigo-300');

    textReturning?.classList.remove('hidden');
    textNew?.classList.add('hidden');
  }

  btnNew?.addEventListener('click', showNew);
  btnReturning?.addEventListener('click', showReturning);
</script>

      {/* Step 3: Understand */}
      <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">
        <div>
          <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-indigo-400 mb-4 block px-3 py-1 rounded bg-indigo-500/10 w-fit">Step 3 — Understand</span>
          <h3 class="text-3xl font-bold mb-6">Know exactly why your AI responds the way it does</h3>
          <p class="text-[var(--color-text-muted)] text-lg leading-relaxed font-medium mb-8">
            When something is wrong you can see it. When something is right you can see why. No more guessing. No more hoping. Just the assembled prompt, right there, in front of you.
          </p>
        </div>
        <div class="relative p-12 rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)]/40 backdrop-blur-sm">
           <div class="flex items-center gap-4 mb-8">
              <div class="w-12 h-12 rounded-full bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-emerald-400">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              </div>
              <h4 class="text-xl font-bold">Visibility Achieved</h4>
           </div>
           <p class="text-lg text-emerald-200/50 leading-relaxed font-medium">
             You now have a source of truth. Your prompts are no longer strings trapped in code. They are managed, verified products.
           </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .text-gradient {
    @apply bg-clip-text text-transparent bg-gradient-to-r from-indigo-400 to-indigo-600;
  }
</style>
