---
interface Props {
  activeSlug?: string;
}

const { activeSlug } = Astro.props;

const sections = [
  {
    title: 'Getting Started',
    items: [
      { label: 'Introduction', href: '/docs' },
      { label: 'Getting Started', href: '/docs/getting-started' },
    ],
  },
  {
    title: 'Language',
    items: [
      { label: 'Language Reference', href: '/docs/language-reference' },
      { label: 'Types', href: '/docs/types' },
      { label: 'Control Flow', href: '/docs/control-flow' },
      { label: 'Fragments', href: '/docs/fragments' },
      { label: 'Response Contracts', href: '/docs/response-contracts' },
    ],
  },
  {
    title: 'Advanced',
    items: [
      { label: 'Versioning', href: '/docs/versioning' },
      { label: 'API Reference', href: '/docs/api-reference' },
    ],
  },
];
---

<nav class="sticky top-16 h-[calc(100vh-4rem)] overflow-y-auto p-6">
  {sections.map((section) => (
    <div class="mb-6">
      <h3 class="mb-2 text-sm font-semibold text-[var(--color-text)]">
        {section.title}
      </h3>
      <ul class="space-y-1">
        {section.items.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[
                'block rounded-lg px-3 py-2 text-sm transition-colors',
                activeSlug === item.href
                  ? 'bg-primary-50 dark:bg-primary-900/20 text-primary-600 dark:text-primary-400 font-medium'
                  : 'text-[var(--color-text-muted)] hover:bg-[var(--color-surface)] hover:text-[var(--color-text)]'
              ]}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  ))}
</nav>
