---
const testimonials = [
  {
    quote: "I've worked on five AI projects. Every single one had the same problem — nobody knew what the LLM was actually receiving. dot-prompt is the first tool that actually fixes this.",
    author: "Sarah Chen",
    role: "Senior AI Engineer at Vercel"
  },
  {
    quote: "Our PM can finally read our prompts. That alone was worth it.",
    author: "David Miller",
    role: "Engineering Manager at Linear"
  },
  {
    quote: "We went from 'why is it doing that' to 'oh, that's exactly why' in about ten minutes.",
    author: "Elena Rodriguez",
    role: "Founder at Stealth AI"
  }
];
---
<section class="py-32 border-t border-[var(--color-border)]/50 relative bg-[var(--color-surface)]/10">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 mb-24 text-center">
    <span class="text-xs font-bold uppercase tracking-[0.2em] text-indigo-400 mb-8 block">What people are saying</span>
    <h2 class="text-4xl sm:text-6xl font-bold tracking-tight mb-8">
      Loved by <span class="text-gradient">builders who ship.</span>
    </h2>
  </div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 grid md:grid-cols-2 lg:grid-cols-3 gap-12">
    {testimonials.map((t) => (
      <div class="group relative p-12 rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg)]/80 backdrop-blur-sm flex flex-col justify-between hover:border-indigo-500/20 transition-colors">
        <blockquote class="text-lg text-[var(--color-text)] font-medium leading-relaxed italic mb-8">
          "{t.quote}"
        </blockquote>
        <div>
           <p class="text-base font-bold text-indigo-200">{t.author}</p>
           <p class="text-xs font-bold uppercase tracking-widest text-[var(--color-text-muted)] mt-1">{t.role}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .text-gradient {
    @apply bg-clip-text text-transparent bg-gradient-to-r from-indigo-400 to-indigo-600;
  }
</style>
