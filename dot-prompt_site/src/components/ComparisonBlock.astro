---
import CodeBlock from './CodeBlock.astro';

interface OutputBranch {
  label: string;
  code: string;
  language?: string;
  params?: { name: string; value: string }[];
}

interface Props {
  prompt: string;
  branches: OutputBranch[];
  promptTitle?: string;
  description: string;
  featureName: string;
}

const { 
  prompt, 
  branches, 
  promptTitle = "example.prompt", 
  description, 
  featureName
} = Astro.props;
---

<div class="comparison-block group relative mb-32 last:mb-0">
  <div class="mb-10 max-w-2xl">
    <h3 class="text-2xl font-bold tracking-tight text-[var(--color-text)] mb-4">
      {featureName}
    </h3>
    <p class="text-[var(--color-text-muted)] leading-relaxed text-base lg:text-lg">
      {description}
    </p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-start">
    <!-- Input Side (Source) - Minimalist -->
    <div class="lg:col-span-5 sticky top-24">
      <div class="flex items-center gap-2 mb-4">
        <span class="text-[10px] font-mono uppercase tracking-[0.2em] text-[var(--color-text-muted)] opacity-70">What you write</span>
        <div class="h-px flex-1 bg-gradient-to-r from-[var(--color-border)] to-transparent opacity-50"></div>
      </div>
      <div class="relative group/source">
        <div class="absolute -inset-2 bg-gradient-to-r from-indigo-500/10 to-transparent rounded-xl blur-xl opacity-0 group-hover/source:opacity-100 transition duration-500"></div>
        <div class="relative bg-transparent border-l border-[var(--color-border)] pl-6 py-2">
          <CodeBlock code={prompt} title={promptTitle} language="dotprompt" />
        </div>
      </div>
    </div>

    <!-- Output Side (Branches) -->
    <div class="lg:col-span-7 space-y-10 relative">
      <div class="flex items-center gap-2 mb-4 lg:hidden">
        <span class="text-[10px] font-mono uppercase tracking-[0.2em] text-[var(--color-text-muted)] opacity-70">What your AI receives</span>
        <div class="h-px flex-1 bg-gradient-to-r from-[var(--color-border)] to-transparent opacity-50"></div>
      </div>

      <!-- Connecting Lines (Visual Decor) -->
      <div class="absolute -left-12 top-0 bottom-0 w-px bg-gradient-to-b from-[var(--color-border)] via-[var(--color-border)]/50 to-transparent hidden lg:block"></div>

      {branches.map((branch, index) => (
        <div 
          class="relative branch-item hover:-translate-y-1 transition-transform"
        >
          <!-- Connection Point -->
          <div class="absolute -left-[47px] top-10 w-12 h-px bg-[var(--color-border)]/50 hidden lg:block"></div>
          <div class="absolute -left-[51px] top-[36px] w-2 h-2 rounded-full bg-[var(--color-accent)] shadow-[0_0_8px_var(--color-accent)] border-2 border-[var(--color-bg)] hidden lg:block"></div>

          <div class="overflow-hidden rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)]/40 backdrop-blur-xl shadow-2xl shadow-black/20 transition-all duration-500 hover:border-indigo-500/40 hover:bg-[var(--color-surface)]/60">
            <div class="flex items-center justify-between px-6 py-4 border-b border-[var(--color-border)]/50 bg-[var(--color-bg)]/30">
              <div class="flex items-center gap-4">
                <span class="text-xs font-bold tracking-widest text-indigo-400 uppercase">
                  {branch.label}
                </span>
                {branch.params && (
                  <div class="flex gap-2 ml-4 hidden sm:flex">
                    {branch.params.map(p => (
                      <div class="flex items-center gap-1.5 px-2 py-0.5 rounded-md bg-indigo-500/10 border border-indigo-500/10">
                        <span class="text-[10px] text-indigo-300/70 font-mono italic">@{p.name}:</span>
                        <span class="text-[10px] text-indigo-200 font-mono font-bold">{p.value}</span>
                      </div>
                    ))}
                  </div>
                )}
              </div>
            </div>
            <div class="p-2">
              <CodeBlock code={branch.code} language={branch.language || "markdown"} />
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  /* Standard styles without animations */
</style>
